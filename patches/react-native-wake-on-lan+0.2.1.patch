+  fun awake(macAddress: String, broadcastAddress: String, port: Double, promise: Promise) {
+    try {
+      val macHex = macAddress.replace(Regex("[^0-9A-Fa-f]"), "")
+      if (macHex.length != 12) {
+        throw IllegalArgumentException("MAC address must contain exactly 6 bytes")
+      }
+
+      val wakePort = port.toInt()
+      if (wakePort < 0 || wakePort > 65535 || wakePort.toDouble() != port) {
+        throw IllegalArgumentException("Wake-on-LAN port must be between 0 and 65535")
+      }
+
+      val magicPacket = createMagicPacket(macHex)
+      val destination = InetAddress.getByName(broadcastAddress)
+
+      DatagramSocket().use { socket ->
+        socket.broadcast = true
+        socket.reuseAddress = true
+        socket.send(DatagramPacket(magicPacket, magicPacket.size, destination, wakePort))
+      }
+
+      promise.resolve(
+        Arguments.createMap().apply {
+          putBoolean("ok", true)
+          putString("broadcastAddress", destination.hostAddress ?: broadcastAddress)
+          putInt("port", wakePort)
+        }
