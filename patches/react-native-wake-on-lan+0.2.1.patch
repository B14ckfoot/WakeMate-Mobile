+  private fun createMagicPacket(macHex: String): ByteArray {
+    val macBytes = ByteArray(6) { index ->
+      macHex.substring(index * 2, index * 2 + 2).toInt(16).toByte()
+    }
+
+    return ByteArray(6 + macBytes.size * 16).apply {
+      for (index in 0 until 6) {
+        this[index] = 0xFF.toByte()
+      }
+
+      for (repeatIndex in 0 until 16) {
+        macBytes.copyInto(
+          destination = this,
+          destinationOffset = 6 + repeatIndex * macBytes.size,
+        )
+      }
+    }
+  }
